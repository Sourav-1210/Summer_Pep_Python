    "x = int(input())\n",
    "y = int(input())\n",
    "op = input()\n",
    "if op == \"+\":\n",
    "    print(x+y)\n",
    "elif op == \"-\":\n",
    "    print(x-y)\n",
    "elif op == \"*\":\n",
    "    print(x*y)\n",
    "else:\n",
    "    print(x/y)"
   ]
  }
